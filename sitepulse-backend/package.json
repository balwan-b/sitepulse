{
  "name": "sitepulse-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.5",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "NODE_ENV=test ARCJET_KEY=test-key BETTER_AUTH_SECRET=test-secret DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitepulse node --import tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "arcjet": "^1.4.0",
    "better-auth": "^1.6.14",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "pg": "^8.21.0",
    "zod": "^4.4.3",
    "helmet": "^6.0.0",
    "express-rate-limit": "^6.8.0",
    "pino": "^8.0.0",
    "@sentry/node": "^7.0.0",
    "prom-client": "^14.0.0"
  },
  "optionalDependencies": {},
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
